# =============================================================================
# LaunchPad Portal — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for local development.
# NEVER commit .env.local or any file containing real secrets to version control.
#
# Production / Preview values are set in Vercel Environment Variables dashboard.
# CI secrets are set in GitHub repository Settings → Secrets and Variables → Actions.
# =============================================================================

# ─── Supabase (required) ─────────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — server-side only (admin operations, bypasses RLS)
# NEVER expose this in client-side code or NEXT_PUBLIC_ variables
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Application ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Resend (email notifications) ────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Sentry (error tracking — production only) ───────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_here
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=launchpad-portal
# SENTRY_AUTH_TOKEN is set in CI/CD secrets only (not needed locally)
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ─── AI Configuration (managed via Admin Settings UI) ────────────────────────
# Claude API keys are managed through the Admin Settings page (US-34)
# and stored encrypted in Supabase Vault — NOT as environment variables.
#
# For local development bootstrap only (optional):
# CLAUDE_API_KEY_BOOTSTRAP=sk-ant-your-bootstrap-key

# =============================================================================
# GitHub Actions CI Secrets (set in GitHub repository settings)
# =============================================================================
# VERCEL_TOKEN           — Vercel API token (create at vercel.com/account/tokens)
# VERCEL_ORG_ID          — Vercel organization/team ID
# VERCEL_PROJECT_ID      — Vercel project ID (from .vercel/project.json after linking)
#
# Note: NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY are also set as GitHub Secrets for the build step.
# =============================================================================
